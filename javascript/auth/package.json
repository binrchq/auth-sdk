{
  "name": "@binrc/auth",
  "version": "1.0.1",
  "description": "Binrc authentication client SDK — top-level redirect, FedCM, signIn/checkSession/signOut",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/binrchq/auth-sdk.git",
    "directory": "javascript/auth"
  },
  "homepage": "https://github.com/binrchq/auth-sdk/tree/main/javascript/auth"
}
